          }
        }
      }
    },
    "You will be notified when the amount of insulin in the Pod reaches a selected level.\n\nScroll to set the number of units (1 to 50) at which you would like to be reminded." : {
      "comment" : "Description text on LowReservoirReminderSetupView",
      "extractionState" : "stale",
