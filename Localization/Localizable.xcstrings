    "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced." : {
      "comment" : "Help text for BeepPreferenceSelectionView",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Připomínky důvěry jsou zvukové signály z přístroje Pod, které lze použít k potvrzení vybraných příkazů, pokud není přístroj Pod ztišen."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Påmindelse om succesfulde aktiviteter er bip fra Pod'en, som kan bruges til at bekræfte valgte kommandoer. når Pod'en ikke er bragt til tavshed."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertrauenserinnerungen sind Pieptöne vom Pod, die verwendet werden können, um ausgewählte Befehle zu bestätigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los recordatorios de confianza son pitidos que emite el Pod que pueden utilizarse para tener certeza de que se han ejecutado comandos cuando no está silenciado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les bips de confirmation sont des bips du Pod qui peuvent être utilisés pour accuser réception des commandes sélectionnées lorsque le Pod n'est pas en mode silencieux."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I promemoria di sicurezza sono segnali acustici emessi dal Pod che possono essere utilizzati per confermare i comandi selezionati quando il Pod non è silenziato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コンフィデンス・リマインダーは、ポッドが消音されていないときに、選択したコマンドを確認するために使用できるポッドからのビープ音です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신뢰 알림은 파드가 음소거되지 않았을 때 선택한 명령을 확인하는 데 사용할 수 있는 파드의 신호음입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillitspåminnelser er pip fra pod som kan brukes til å bekrefte valgte kommandoer når pod ikke er satt til lydløs."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit zijn meldingen die met piepjes uit de Pod komen en kunnen worden gebruikt ter bevestiging van geselecteerde opdrachten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notificările de confirmare sunt semnale sonore de la pompă care pot fi folosite pentru a confirma comenzile selectate atunci când pompa nu este pe modul silențios."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доверенные звуковые сигналы от Пода, которые позволяют распознать выбранные команды, когда Под не заглушен."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zvukové upozornenia Podu, ktoré môžu slúžiť na potvrdenie vybraných príkazov ak Pod nie je stíšený."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opomniki zaupanja so zvočni signali naprave Pod, s katerimi lahko potrdite izbrane ukaze, kadar naprava Pod ni utišana."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bekräftelseljud är pip från podden (när den inte är tystad) som kan användas som bekräftelser på utförda kommandon."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигнали підтвердження — це звукові сигнали Podʼа, які можна використовувати для підтвердження вибраних команд."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lời nhắc là những tiếng bíp từ Pod có thể được sử dụng để xác nhận các lệnh đã chọn khi Pod không ở chế độ im lặng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        }
      }
    },
    "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %1$@ automatically adjusts delivery, no confidence reminders are used." : {
      "comment" : "Description for BeepPreference.manualCommands (1: appName)",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Připomenutí důvěry zazní pro příkazy, které iniciujete, jako je bolus, zrušení bolusu, pozastavení, obnovení, připomenutí uložení oznámení atd. Když %@ automaticky upravuje podávání, nepoužívají se žádná připomenutí důvěry."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
