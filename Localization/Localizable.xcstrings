        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod keep alive activat atunci când aplicația este în prim-plan cu telefonul deblocat. Cerere suplimentară privind starea podului emisă după 2 minute, 40 de secunde."
