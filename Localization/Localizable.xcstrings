        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Функция поддержания жизни стручков включена, когда приложение находится на переднем плане, а телефон разблокирован. Дополнительный запрос статуса стручка выдается через 2 минуты 40 секунд."
          }
