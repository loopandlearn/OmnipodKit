    "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“" : {
      "comment" : "Alert message body for confirm pod attachment",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Váš Pod může stále dodávat inzulín.\nVyjměte jej z těla a klepněte na \"Pokračovat\"."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din Pod leverer muligvis stadig insulin.\nFjern den fra din krop og tryk derefter på \"Fortsæt\"."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Pod gibt möglicherweise immer noch Insulin ab.\nEntferne ihn vom Körper und tippe dann auf „Weiter“."
          }
        },
        "en" : {
