        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les bips de confirmation retentiront pour les commandes que vous initiez, comme un bolus, l'annulation d'un bolus, la suspension, la reprise, la sauvegarde des rappels de notification, etc. Lorsque %@ ajuste automatiquement l'administration, aucun bip de confirmation n'est utilisé."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I promemoria di sicurezza suoneranno per i comandi che avvii, come bolo, annullamento bolo, sospensione, ripresa, salvataggio promemoria notifiche, ecc. Quando %@ regola automaticamente l'erogazione, non vengono utilizzati promemoria di sicurezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確信度リマインダーは、ボーラス、ボーラスキャンセル、サスペンド、レジューム、 通知リマインダーの保存など、あなたが開始したコマンドに対して鳴ります。%@が自動的に分娩を調節するときは、確信度リマインダーは使用されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "추가, 추가 취소, 일시 중단, 다시 시작, 알림 알림 저장 등과 같이 사용자가 시작한 명령에 대해 신뢰도 알림이 울립니다. %@가 자동으로 배달을 조정하는 경우에는 신뢰도 알림이 사용되지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillitspåminnelser høres for kommandoer du starter, for eksempel bolus, avbryt bolus, suspendere, gjenoppta, lagre varslingspåminnelser osv. Når %@ automatisk justerer leveringen, brukes ingen tillitspåminnelser."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Piepjes uit de Pod zullen klinken voor commando's die je hebt geïnitieerd, zoals bolus, annulering, geschorst, hervatten, opslaan van meldingen etc. Als %@ automatisch de levering wijzigt, worden er geen piepjes gebruikt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notificările de confirmare vor suna pentru comenzile pe care le inițiați, cum ar fi bolus, anulare bolus, suspendare, reluare, salvare mementouri de notificare etc. Când %@ ajustează automat administrarea, nu se folosesc notificări de confirmare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaupanja vredni opomniki se bodo oglasili za ukaze, ki jih sprožite, kot so bolus, preklic bolusa, prekinitev, nadaljevanje, opomniki za shranjevanje obvestil itd. Ko %@ samodejno prilagodi dostavo, se opomniki zaupanja ne uporabljajo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bekräftelseljud kommer att pipa för för alla pumpkommandon du ger, som bolus, avbryt bolus, pausa pump, återuppta insulintillförsel, spara påminnelser etc. När %@ automatiskt justerar insulintillförsel kommer inga pip att ljuda."
