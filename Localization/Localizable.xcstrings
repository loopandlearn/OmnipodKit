    "Keep the RileyLink about 6 inches from the pod during pairing." : {
      "comment" : "Label text for step 2 of Eros pair pod instructions",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احتفظي بالرايلي لينك على بعد 6 بوصات تقريباً من الكبسولة أثناء الاقتران."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Během párování udržujte zařízení RileyLink ve vzdálenosti asi 6 palců od lusku."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hold RileyLink ca. 15 cm fra bælgen under parring."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie den RileyLink während des Koppelns etwa 15 cm von der Schote entfernt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep the RileyLink about 6 inches from the pod during pairing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenga el RileyLink a unos 15 cm de la vaina durante el emparejamiento."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pidä RileyLink noin 6 tuuman päässä podista pariliitoksen aikana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gardez le RileyLink à environ 15 cm (6 pouces) du Pod pendant l'association."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שמור את RileyLink במרחק של כ-6 אינץ' מהתרמיל במהלך ההתאמה."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A RileyLinket a párosítás során tartsa a hüvelytől kb. 15 cm-re."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durante l'accoppiamento, tenere il RileyLink a circa 15 cm dal baccello."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ペアリング中は、ライリーリンクをポッドから約15cm離す。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "페어링하는 동안 RileyLink를 포드에서 6인치 정도 떨어진 곳에 두세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hold RileyLink ca. 15 cm fra podet under sammenkoblingen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Houd de RileyLink ongeveer 6 inch van de peul tijdens het koppelen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podczas parowania trzymaj RileyLink w odległości około 6 cali od kapsuły."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha o RileyLink a cerca de 15 cm da cápsula durante o emparelhamento."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Țineți RileyLink la aproximativ 15 cm de capsulă în timpul împerecherii."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Во время сопряжения держите RileyLink на расстоянии около 6 дюймов от стручка."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Počas párovania udržujte zariadenie RileyLink vo vzdialenosti približne 6 palcov od struku."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med parjenjem naj bo naprava RileyLink od stroka oddaljena približno 6 centimetrov."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håll RileyLink ca 6 tum från kapseln under parkopplingen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
