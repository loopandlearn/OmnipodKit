        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בדוק תרמיל, החל על האתר ולאחר מכן אשר קובץ מצורף לתרמיל."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ellenőrizze a podot, alkalmazza a helyszínen, majd erősítse meg a pod rögzítését."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
