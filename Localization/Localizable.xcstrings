    "No %@RileyLinks found. They will appear here when discovered." : {
      "comment" : "A message that appears when no RileyLinks are found.",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لم يتم العثور على %@RileyLinks. ستظهر هنا عند اكتشافها."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nebyly nalezeny žádné %@RileyLinks. Objeví se zde, jakmile budou nalezeny."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen %@RileyLinks fundet. De vil blive vist her, når de bliver fundet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keine %@RileyLinks gefunden. Sie werden hier erscheinen, wenn sie entdeckt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No %@RileyLinks found. They will appear here when discovered."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se han encontrado %@RileyLinks. Aparecerán aquí cuando se descubran."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ei löytynyt %@RileyLinkkejä. Ne ilmestyvät tänne, kun ne löydetään."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucun %@RileyLinks n'a été trouvé. Ils apparaîtront ici lorsqu'ils seront découverts."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לא נמצא% @RileyLinks. הם יופיעו כאן כאשר יתגלו."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nem találtunk %@RileyLinks-et. Itt fognak megjelenni, ha megtaláljuk őket."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non sono stati trovati %@RileyLinks. Appariranno qui quando verranno scoperti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ライリーリンクが見つかりません。発見され次第、ここに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "라일리링크를 찾을 수 없습니다. 발견되면 여기에 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen %@RileyLinks funnet. De vil vises her når de oppdages."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen %@RileyLinks gevonden. Ze zullen hier verschijnen zodra ze ontdekt zijn."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie znaleziono %@RileyLinks. Pojawią się tutaj, gdy zostaną znalezione."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não foram encontrados %@RileyLinks. Eles aparecerão aqui quando forem descobertos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nu s-au găsit %@RileyLinks. Acestea vor apărea aici atunci când vor fi descoperite."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не найдено ни одной %@RileyLinks. Они появятся здесь, когда будут найдены."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenašli sa žiadne %@RileyLinks. Zobrazia sa tu, keď budú objavené."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ni bilo najdenih %@RileyLinks. Po odkritju se bodo pojavile tukaj."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inga %@RileyLinks hittades. De kommer att visas här när de upptäcks."
          }
        },
