          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod je pripravljen za uporabo.\n\nPri nastavitvi je bil za ta pod načrtovan privzeti opomnik. Opomnik lahko spremenite na primernejši čas v nastavitvah za obvestila za pod."
