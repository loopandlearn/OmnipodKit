    "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced." : {
      "comment" : "Help text for BeepPreferenceSelectionView",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Připomínky důvěry jsou zvukové signály z přístroje Pod, které lze použít k potvrzení vybraných příkazů, pokud není přístroj Pod ztišen."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Påmindelse om succesfulde aktiviteter er bip fra Pod'en, som kan bruges til at bekræfte valgte kommandoer. når Pod'en ikke er bragt til tavshed."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertrauenserinnerungen sind Pieptöne vom Pod, die verwendet werden können, um ausgewählte Befehle zu bestätigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los recordatorios de confianza son pitidos que emite el Pod que pueden utilizarse para tener certeza de que se han ejecutado comandos cuando no está silenciado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les bips de confirmation sont des bips du Pod qui peuvent être utilisés pour accuser réception des commandes sélectionnées lorsque le Pod n'est pas en mode silencieux."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I promemoria di sicurezza sono segnali acustici emessi dal Pod che possono essere utilizzati per confermare i comandi selezionati quando il Pod non è silenziato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コンフィデンス・リマインダーは、ポッドが消音されていないときに、選択したコマンドを確認するために使用できるポッドからのビープ音です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신뢰 알림은 파드가 음소거되지 않았을 때 선택한 명령을 확인하는 데 사용할 수 있는 파드의 신호음입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillitspåminnelser er pip fra pod som kan brukes til å bekrefte valgte kommandoer når pod ikke er satt til lydløs."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit zijn meldingen die met piepjes uit de Pod komen en kunnen worden gebruikt ter bevestiging van geselecteerde opdrachten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notificările de confirmare sunt semnale sonore de la pompă care pot fi folosite pentru a confirma comenzile selectate atunci când pompa nu este pe modul silențios."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доверенные звуковые сигналы от Пода, которые позволяют распознать выбранные команды, когда Под не заглушен."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zvukové upozornenia Podu, ktoré môžu slúžiť na potvrdenie vybraných príkazov ak Pod nie je stíšený."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opomniki zaupanja so zvočni signali naprave Pod, s katerimi lahko potrdite izbrane ukaze, kadar naprava Pod ni utišana."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bekräftelseljud är pip från podden (när den inte är tystad) som kan användas som bekräftelser på utförda kommandon."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигнали підтвердження — це звукові сигнали Podʼа, які можна використовувати для підтвердження вибраних команд."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lời nhắc là những tiếng bíp từ Pod có thể được sử dụng để xác nhận các lệnh đã chọn khi Pod không ở chế độ im lặng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders are beeps from the Pod which can be used to acknowledge selected commands when the Pod is not silenced."
          }
        }
      }
    },
    "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %1$@ automatically adjusts delivery, no confidence reminders are used." : {
      "comment" : "Description for BeepPreference.manualCommands (1: appName)",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Připomenutí důvěry zazní pro příkazy, které iniciujete, jako je bolus, zrušení bolusu, pozastavení, obnovení, připomenutí uložení oznámení atd. Když %@ automaticky upravuje podávání, nepoužívají se žádná připomenutí důvěry."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Påmindelser om succesfulde handlinger vil lyde for de kommandoer du sætter igang, annulleret, suspenderet, genoptaget bolus, gemme notifikationspåmindelser etc. Når %@ automatisk justerer tilførslen, bliver påmindelser om succesfulde handlinger ikke benyttet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertrauenserinnerungen ertönen für von Ihnen initiierte Befehle, wie Bolus, Bolus abbrechen, Unterbrechen, Fortsetzen, Benachrichtigungserinnerungen speichern usw. Wenn %@ die Abgabe automatisch anpasst, werden keine Vertrauenserinnerungen verwendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los recordatorios de confianza sonarán para los comandos que seleccione, como bolo, cancelar bolo, suspender, reanudar, guardar recordatorios de notificación, etc. Cuando %@ ajusta automáticamente la administración de insulina, no se utilizan recordatorios de confianza."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les rappels de confirmation retentiront pour les commandes que vous initiez, comme administrer ou annuler un bolus, suspendre, reprendre, enregistrer les rappels de notification, etc. Lorsque %@ ajuste automatiquement l'administration, aucun rappel de confirmation n’est utilisé."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I promemoria di sicurezza suoneranno per i comandi che avvii, come bolo, annullamento bolo, sospensione, ripresa, salvataggio promemoria notifiche, ecc. Quando %@ regola automaticamente l'erogazione, non vengono utilizzati promemoria di sicurezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "確信度リマインダーは、ボーラス、ボーラスキャンセル、サスペンド、レジューム、 通知リマインダーの保存など、あなたが開始したコマンドに対して鳴ります。%@が自動的に分娩を調節するときは、確信度リマインダーは使用されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "추가, 추가 취소, 일시 중단, 다시 시작, 알림 알림 저장 등과 같이 사용자가 시작한 명령에 대해 신뢰도 알림이 울립니다. %@가 자동으로 배달을 조정하는 경우에는 신뢰도 알림이 사용되지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillitspåminnelser høres for kommandoer du starter, for eksempel bolus, avbryt bolus, suspendere, gjenoppta, lagre varslingspåminnelser osv. Når %@ automatisk justerer leveringen, brukes mistillitspåminnelser."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bevestigingsherinneringen zijn hoorbaar voor opdrachten die je start, zoals bolussen, bolus annuleren, onderbreken, hervatten, meldingsherinneringen opslaan, enz. Wanneer %@ de toediening automatisch aanpast, zijn er geen bevestigingsherinneringen hoorbaar."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przypomnienia (sygnały dźwiękowe) będą emitowane w przypadku poleceń, które zainicjujesz, takich jak bolus, anulowanie bolusa, wstrzymanie, wznowienie, zapisanie przypomnień o powiadomieniach itp. Kiedy %@ automatycznie dostosowuje podawanie, nie są używane żadne sygnały dźwiękowe."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mementourile de confirmare vor suna pentru comenzile pe care le inițiați, precum bolus, anularea bolusului, suspendare, reluare, salvarea mementourilor de confirmare etc. Când %@ ajustează automat administrarea, nu sunt folosite mementouri de confirmare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Напоминания будут звучать для инициированных вами команд, таких как болюс, отмена болюса, приостановка, возобновление, напоминания о сохранении уведомлений и т.д. Когда %@ автоматически регулирует подачу инсулина, напоминания не будут использоваться."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pripomienky spoľahlivosti zaznejú pri príkazoch, ktoré spustíte, ako je bolus, zrušenie bolusu, pozastavenie, obnovenie, uloženie upozornení atď. Keď %@ automaticky upraví podanie, nepoužijú sa žiadne pripomenutia spoľahlivosti."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaupanja vredni opomniki se bodo oglasili za ukaze, ki jih sprožite, kot so bolus, preklic bolusa, prekinitev, nadaljevanje, opomniki za shranjevanje obvestil itd. Ko %@ samodejno prilagodi dostavo, se opomniki zaupanja ne uporabljajo."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bekräftelseljud kommer att pipa för för alla pumpkommandon du ger, som bolus, avbryt bolus, pausa pump, återuppta insulintillförsel, spara påminnelser etc. När %@ automatiskt justerar insulintillförsel kommer inga pip att ljuda."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emniyet hatırlatıcıları, bolus, bolus iptali, askıya alma, devam ettirme, bildirim hatırlatıcılarını kaydetme gibi başlattığınız komutlar için çalacaktır. %@ iletimi otomatik olarak ayarladığında emniyet hatırlatıcıları kullanılmaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thông báo xác nhận sẽ phát tiếng bíp khi bạn thực hiện các lệnh, chẳng hạn như tiêm bolus, hủy bolus, tạm dừng, tiếp tục, lưu thông báo nhắc, v.v. Khi %@ tự động điều chỉnh việc tiêm, các thông báo xác nhận sẽ không được sử dụng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound for commands you initiate, like bolus, cancel bolus, suspend, resume, save notification reminders, etc. When %@ automatically adjusts delivery, no confidence reminders are used."
          }
        }
      }
    },
    "Confidence reminders will sound when %1$@ automatically adjusts delivery as well as for commands you initiate." : {
      "comment" : "Description for BeepPreference.extended (1: appName)",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound when %@ automatically adjusts delivery as well as for commands you initiate."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Připomenutí důvěry zazní, když %@ automaticky upraví dodávku, a také pro příkazy, které iniciujete."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Påmindelser om succesfulde handlinger vil lyde, når %@ automatisk justerer tilførslen og de kommandoer, du sætter igang."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertrauenserinnerungen ertönen, wenn %@ die Lieferung automatisch anpasst, sowie für von Ihnen initiierte Befehle."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound when %@ automatically adjusts delivery as well as for commands you initiate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recordatorios de confianza sonarán cuando %@ automáticamente ajuste la administración de insulina, así como para los comandos que selecciones."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound when %@ automatically adjusts delivery as well as for commands you initiate."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des rappels de confirmation retentiront lorsque %@ ajustera automatiquement l'administration ainsi que pour les commandes que vous lancez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound when %@ automatically adjusts delivery as well as for commands you initiate."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confidence reminders will sound when %@ automatically adjusts delivery as well as for commands you initiate."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I promemoria di sicurezza suoneranno quando %@ regola automaticamente l'erogazione e per i comandi che avvii."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コンフィデンス・リマインダーは、%@が自動的に配信を調整するときや、あなたが開始したコマンドに対して鳴ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신뢰 알림은 %@가 자동으로 배달을 조정할 때와 사용자가 시작한 명령에 대해 울립니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillitspåminnelser vil høres når %@ automatisk justerer leveringen så vel som for kommandoer du starter."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bevestigingsherinneringen zijn hoorbaar wanneer %@ de toediening automatisch aanpast, evenals voor opdrachten die je geeft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przypomnienia potwierdzające są emitowane, gdy %@ automatycznie dostosowuje podawanie insuliny, a także w przypadku poleceń inicjowanych przez użytkownika."
          }
