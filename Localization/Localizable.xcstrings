    "Select the particular Omnipod Pod type to use with %1$@. Be sure to select the correct Pod type or %2$@ will not be able to communicate with it." : {
      "comment" : "Help text for Omnipod Pod type selection (1: appName) (2: appName)",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدد نوع جراب أومنيبود معين لاستخدامه مع %@. تأكد من تحديد نوع الجراب الصحيح وإلا لن تتمكن %@ من الاتصال به."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyberte konkrétní typ podstavce Omnipod, který chcete použít s %@. Ujistěte se, že jste vybrali správný typ podstavce, jinak s ním %@ nebude moci komunikovat."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vælg den særlige Omnipod Pod-type, der skal bruges med %@. Sørg for at vælge den rigtige Pod-type, ellers kan %@ ikke kommunikere med den."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie den speziellen Omnipod-Pod-Typ für die Verwendung mit %@. Achten Sie darauf, den richtigen Pod-Typ auszuwählen, sonst kann der %@ nicht mit ihm kommunizieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
