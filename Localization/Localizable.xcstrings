        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Pod keep alive engedélyezve van, ha az alkalmazás előtérben van, és a telefon nincs lezárva. További pod állapotkérés 2 perc 40 másodperc után."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod keep alive abilitato quando l'app è in primo piano con il telefono sbloccato. Richiesta di stato del pod aggiuntivo emessa dopo 2 minuti e 40 secondi."
