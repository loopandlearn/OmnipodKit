          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポッドの位置を調整するか、iPhoneの設定でBluetoothをオフにしてからオンにする。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod 위치를 조정하거나 iPhone 설정에서 Bluetooth를 껐다가 켜보세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prøv å justere posisjonen til podden eller slå Bluetooth av og på i iPhone-innstillingene"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
