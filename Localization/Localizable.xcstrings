    "Pod keep alive disabled. Pod disconnects 3 minutes after last message exchange (nominal behavior)." : {
      "comment" : "Description for PodKeepAlive.disabled",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تعطيل إبقاء الكبسولة على قيد الحياة. يتم قطع اتصال الكبسولة بعد 3 دقائق من آخر تبادل للرسائل (سلوك اسمي)."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod udržet při životě vypnuto. Pod se odpojí 3 minuty po poslední výměně zpráv (nominální chování)."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod holder sig i live deaktiveret. Pod'en afbryder forbindelsen 3 minutter efter sidste beskedudveksling (nominel adfærd)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod-Überwachung deaktiviert. Der Pod trennt die Verbindung 3 Minuten nach dem letzten Nachrichtenaustausch (nominales Verhalten)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod keep alive disabled. Pod disconnects 3 minutes after last message exchange (nominal behavior)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod keep alive desactivado. El pod se desconecta 3 minutos después del último intercambio de mensajes (comportamiento nominal)."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod keep alive pois käytöstä. Pod katkaisee yhteyden 3 minuutin kuluttua viimeisestä viestinvaihdosta (nimellinen käyttäytyminen)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod keep alive désactivé. Le pod se déconnecte 3 minutes après le dernier échange de messages (comportement nominal)."
          }
        },
