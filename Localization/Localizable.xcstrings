          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Напоминания будут звучать, когда %@ автоматически регулирует подачу инсулина, а также для команд, которые вы инициируете."
          }
        },
        "sk" : {
          "stringUnit" : {
