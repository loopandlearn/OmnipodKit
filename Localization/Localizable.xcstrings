    "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled." : {
      "comment" : "Success message for play test beeps",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Příkaz k testování přehrávání byl úspěšně odeslán.\n\nPokud jste z Podu neslyšeli žádné pípnutí, může být piezoelektrický reproduktor v Podu poškozený nebo vypnutý."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La commande de test de lecture des bips a été envoyée avec succès. \n \nSi vous n'avez entendu aucun bip provenant de votre Pod, le haut-parleur de votre Pod est peut-être cassé ou désactivé."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comando di test dei segnali acustici inviato con successo.\n\nSe non hai sentito alcun segnale acustico dal tuo Pod, lo speaker piezoelettrico del tuo Pod potrebbe essere guasto o disattivato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレイテストビープコマンドが正常に送信された。\n\nPodからビープ音が聞こえない場合は、Podのピエゾスピーカーが壊れているか、無効になっている可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "재생 테스트 신호음 명령이 성공적으로 전송되었습니다.\n\n파드에서 신호음이 들리지 않았다면 파드의 피에조 스피커가 고장났거나 비활성화된 것일 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kommandoen Spill av testpip sendt vellykket.\n\nHvis du ikke hørte noen pip fra pod, kan piezohøyttaleren i pod være ødelagt eller deaktivert."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Test beeps commando met succes verzonden.\n\nAls je geen beeps vanuit je pod hebt gehoord is het goed mogelijk dat de speaker van de pod kapot is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comanda de semnale sonore de testare a fost trimisă cu succes.\n\nDacă nu ați auzit niciun semnal sonor de la pompă, difuzorul piezo din pompă poate fi stricat sau dezactivat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uspešno poslan ukaz za preizkus predvajanja.\n\nČe iz vašega Poda ni bilo slišati nobenega piska, je piezoelektrični zvočnik v vašem Podu morda pokvarjen ali onemogočen."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kommandot för uppspelning av testljud skickades.\n\nOm du inte hörde några pip från din podd, är det troligt att piezohögtalaren i din podd är sönder eller inaktiverad."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Play test beeps command sent successfully.\n\nIf you did not hear any beeps from your Pod, the piezo speaker in your Pod may be broken or disabled."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lệnh phát tiếng bíp kiểm tra đã được gửi thành công.\n\nNếu bạn không nghe thấy bất kỳ tiếng bíp nào từ Pod, loa piezo trong Pod có thể bị hỏng hoặc bị tắt."
          }
