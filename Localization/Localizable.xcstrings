    "If you cancel Pod setup, the current Pod will be deactivated and will be unusable." : {
      "comment" : "Alert message body for confirm pod attachment",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا قمت بإلغاء إعداد البود، سيتم إلغاء تنشيط البود الحالي وسيكون غير قابل للاستخدام."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud nastavení Podu zrušíte, aktuální Pod bude deaktivován a nebude možné jej používat."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du annullerer Pod-opsætningen, deaktiveres den aktuelle Pod og den vil være ubrugelig."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Du die Einrichtung abbrichst, dann wird der Pod deaktiviert und unbrauchbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you cancel Pod setup, the current Pod will be deactivated and will be unusable."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si cancela la configuración del Pod, el Pod actual se desactivará y quedará inutilizable."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you cancel Pod setup, the current Pod will be deactivated and will be unusable."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous annulez la configuration du Pod, le Pod actuel sera désactivé et sera inutilisable."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you cancel Pod setup, the current Pod will be deactivated and will be unusable."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you cancel Pod setup, the current Pod will be deactivated and will be unusable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se annulli la configurazione del Pod, il Pod corrente verrà disattivato e sarà inutilizzabile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podのセットアップをキャンセルすると、現在のPodは無効になり、使用できなくなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "파드 설정을 취소하면 현재 파드가 비활성화되어 사용할 수 없게 됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du avbryter Pod-oppsettet, vil gjeldende Pod deaktiveres og bli ubrukelig."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als je de Podinstallatie annuleert, wordt de huidige Pod gedeactiveerd en onbruikbaar."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli anulujesz konfigurację POD'a, bieżący POD zostanie dezaktywowany i nie będzie można go używać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you cancel Pod setup, the current Pod will be deactivated and will be unusable."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă anulați configurarea pompei, pompa actuală va fi dezactivată și va fi inutilizabilă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы отмените настройку пода, текущий под будет деактивирован и станет непригодным для использования."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ak zrušíte nastavenie Podu, aktuálny Pod bude deaktivovaný a nebude možné ho používať."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Če prekličete nastavitev podov, bo trenutni pod deaktiviran in ga ne bo mogoče uporabljati."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om du avbryter din podinställning, kommer din podd att avaktiveras och sluta fungera."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod kurulumunu iptal ederseniz, mevcut Pod devre dışı bırakılır ve kullanılamaz hale gelir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо ви скасуєте налаштування Pod'a, поточний Pod буде дезактивовано та стане непридатним для використання."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu bạn hủy cấu hình pod, pod hiện tại sẽ bị hủy kích hoạt và sẽ không sử dụng được nữa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您现在取消Pod 设置，当前Pod将被停用并报废。"
          }
        }
      }
    },
