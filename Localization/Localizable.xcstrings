        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ha ristabilito la comunicazione con il Pod sul tuo corpo.\n\nI registri di erogazione dell'insulina sono stati aggiornati e dovrebbero corrispondere a quanto effettivamente erogato.\n\nOra puoi continuare a usare normalmente %@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@があなたの体のポッドとの通信を回復しました。\n\nインスリン投与記録が更新され、実際に投与されたものと一致しているはずです。\n\n%@は通常通り使用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@가 본체에 있는 포드와의 통신을 복구했습니다.\n\n인슐린 전달 기록이 업데이트되었으며 실제로 전달된 것과 일치해야 합니다.\n\n이제 %@를 정상적으로 계속 사용할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har gjenopprettet kommunikasjonen med pod på kroppen din.\n\nInsulintilførselsjournaler er oppdatert og bør samsvare med det som faktisk ble levert. \n\n Du kan fortsette å bruke %@ normalt nå."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ heeft de communicatie met de pod op je lichaam hersteld. \n\nDe gegevens over insulinetoediening zijn bijgewerkt en moeten overeenkomen met wat daadwerkelijk is toegediend. \n\nJe kunt %@ nu weer normaal gebruiken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ a reluat comunicarea cu dispozitivul de pe corpul dumneavoastră. \n \nÎnregistrările administrării de insulină au fost actualizate și ar trebui să corespundă cu ceea ce a fost efectiv administrat. \n \n Acum puteți continua să utilizați %@ în mod normal."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ je obnovil komunikacijo z modulom na vašem telesu.\n\nZapisi o dostavi insulina so bili posodobljeni in bi se morali ujemati z dejansko dostavljenim inzulinom.\n\nZdaj lahko še naprej normalno uporabljate %@."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ har återställt kommunikationen med podden på din kropp.\n\nInsulinposterna har uppdaterats och ska matcha det som faktiskt har levererats.\n\nDu kan fortsätta att använda %@ normalt nu."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ đã khôi phục liên lạc với pod trên cơ thể bạn.\n\nCác bản ghi về việc tiêm insulin đã được cập nhật và hiện khớp với lượng insulin thực tế đã được tiêm.\n\nBạn có thể tiếp tục sử dụng %@ như bình thường."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        }
      }
    },
