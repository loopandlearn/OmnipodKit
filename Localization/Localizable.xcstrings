          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecteer het specifieke Omnipod Pod-type voor gebruik met %@. Zorg ervoor dat u het juiste Pod-type selecteert, anders kan %@ er niet mee communiceren."
          }
        },
        "pl" : {
          "stringUnit" : {
