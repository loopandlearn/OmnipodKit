    "%1$@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %2$@ normally now." : {
      "comment" : "Text body for page showing insulin uncertainty has been recovered (1: appName) (2: appName)",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ obnovil komunikaci s modulem na vašem těle.\n\nZáznamy o dodávkách inzulínu byly aktualizovány a měly by odpovídat tomu, co bylo skutečně dodáno.\n\nNyní můžete pokračovat v normálním používání %@."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ has recovered communication with the pod on your body.\n\nInsulin delivery records have been updated and should match what has actually been delivered.\n\nYou may continue to use %@ normally now."
          }
        },
