        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thời gian trên máy bơm của bạn khác với thời gian hiện tại. Bạn có muốn cập nhật thời gian trên máy bơm của mình đến thời điểm hiện tại không?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
