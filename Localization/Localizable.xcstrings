    " or select a different RileyLink; power the RileyLink device off and on" : {
      "comment" : "delivery uncertainty recovery phrase when using a RileyLink",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " أو اختر RileyLink مختلفاً؛ قم بإيقاف تشغيل جهاز RileyLink وتشغيله"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " nebo vyberte jiné zařízení RileyLink; vypněte a zapněte zařízení RileyLink."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " eller vælg en anden RileyLink; sluk og tænd for RileyLink-enheden"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " oder wählen Sie einen anderen RileyLink; schalten Sie das RileyLink-Gerät aus und ein"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " or select a different RileyLink; power the RileyLink device off and on"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " o seleccione un RileyLink diferente; apague y encienda el dispositivo RileyLink"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " tai valitse toinen RileyLink; sammuta ja käynnistä RileyLink-laite."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " ou sélectionner un autre RileyLink ; éteindre et rallumer l'appareil RileyLink"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " או בחר RileyLink אחר; כבה והפעל את מכשיר ה- RileyLink"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " vagy válasszon ki egy másik RileyLink-et; kapcsolja ki és be a RileyLink eszközt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " o selezionare un RileyLink diverso; spegnere e riaccendere il dispositivo RileyLink"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "または別のライリーリンクを選択する。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " 또는 다른 라일리링크를 선택하거나 라일리링크 장치의 전원을 껐다가 켭니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " eller velg en annen RileyLink; slå RileyLink-enheten av og på"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " of selecteer een andere RileyLink; schakel het RileyLink-apparaat uit en in"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " lub wybierz inne urządzenie RileyLink; wyłącz i włącz zasilanie urządzenia RileyLink"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " ou selecionar um RileyLink diferente; desligar e ligar o dispositivo RileyLink"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " sau selectați un alt RileyLink; opriți și porniți dispozitivul RileyLink"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " или выберите другой RileyLink; выключите и включите устройство RileyLink"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " alebo vyberte iné zariadenie RileyLink; vypnite a zapnite zariadenie RileyLink"
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
