          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обычный режим работы, при котором звуковые сигналы используются для всех оповещений Пода и при включенных доверенных напоминаниях."
          }
        },
        "sk" : {
