    "Change Pod now. Insulin delivery will stop 8 hours after the Pod has expired or when no more insulin remains." : {
      "comment" : "The action string on pod status page when pod expired",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "غيّر البود الآن. سيتوقف توصيل الأنسولين بعد 8 ساعات من انتهاء صلاحية البود أو عندما ينفد الأنسولين تمامًا."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vyměňte pod. Výdej inzulinu se zastaví 8 hodin poté, co pod vypršel, nebo když už v něm nezbývá žádný inzulín."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skift Pod nu. Insulintilførsel stopper 8 timer efter, at Pod'en er udløbet, eller når der ikke er mere insulin tilbage."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod jetzt wechseln. Die Insulinabgabe stoppt 8 Stunden nach Ablauf des Pods oder wenn kein Insulin mehr vorhanden ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change Pod now. Insulin delivery will stop 8 hours after the Pod has expired or when no more insulin remains."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambie el Pod ahora. La administración de insulina se detendrá 8 horas después de que el Pod haya caducado o cuando no quede más insulina."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change Pod now. Insulin delivery will stop 8 hours after the Pod has expired or when no more insulin remains."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remplacer le pod maintenant. L'administration d'insuline s'arrêtera 8 heures après l'expiration du pod ou lorsque qu'il ne restera plus d'insuline."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change Pod now. Insulin delivery will stop 8 hours after the Pod has expired or when no more insulin remains."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change Pod now. Insulin delivery will stop 8 hours after the Pod has expired or when no more insulin remains."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia Pod ora. L'erogazione dell'insulina si interromperà dopo 8 ore dalla scadenza del Pod o quando non rimane più insulina nel Pod."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今すぐポッドを交換してください。ポッドの有効期限が切れるか、インスリンの残量がなくなると、インスリンの供給は8時間後に停止します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지금 파드를 변경하세요. Pod가 만료된 후 8시간이 지나거나 더 이상 인슐린이 남아 있지 않으면 인슐린 공급이 중단됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bytt Pod nå. Insulintilførselen vil stoppe 8 timer etter at pod har utløpt eller når det ikke er mer insulin igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vervang Pod nu. De insulinetoediening stop 8 uur nadat de Pod is verlopen of wanneer er geen insuline meer over is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zmień POD teraz. Podawanie insuliny zostanie zatrzymane 8 godzin po wygaśnięciu POD'a lub gdy zabraknie insuliny."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change Pod now. Insulin delivery will stop 8 hours after the Pod has expired or when no more insulin remains."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schimbați pompa acum. Administrarea insulinei se va opri la 8 ore după expirarea pompei sau când nu mai rămâne deloc insulină."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Замените под сейчас. Подача инсулина прекратится через 8 часов после истечения срока действия пода или когда инсулина больше не останется."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihneď vymeniť pod. Podávanie inzulínu sa zastaví o 8 hodín alebo keď sa minie inzulín."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spremeni Pod zdaj. Dostavljanje insulina se bo ustavilo 8 ur po izteku roka uporabe Poda ali ko ne bo več insulina."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Byt podd nu. Insulintillförsel kommer att upphöra 8 timmar efter att podd går ut eller tills att inget insulin återstår."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod'u şimdi değiştirin. İnsülin iletimi, podun süresi dolduktan 8 saat sonra veya insülin kalmadığında duracaktır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Замініть Pod. Подача інсуліну буде зупинена через 8 годин після закінчення терміну дії Pod'a або коли резервуар буде порожній."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thay pod ngay. Insulin sẽ ngưng khi pod hết hạn 8 giờ tới hoặc khi không còn insulin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "现在更换Pod 。Pod 过期后的8小时后胰岛素输注将完全停止。"
          }
        }
      }
    },
