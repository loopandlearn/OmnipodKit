    "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping." : {
      "comment" : "Help text for Silence Pod view",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وضع كتم صوت البود يقوم بإيقاف جميع صفارات تنبيهات البود وصفارات تذكيرات التأكيد."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Režim Silence Pod potlačuje všechna upozornění Pod a potvrzovací pípání."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lydløs Pod tilstand undertrykker alle Pod alarmer og bekræftelsespåmindelsesbip."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stille Pod Modus unterdrückt alle Pod Warnungen und Bestätigungs-Erinnerung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El modo Silence Pod reprime toda la alerta de Pod y el recordatorio de confirmación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mode Pod Silencieux supprime tous les bips d'alerte et de rappel de confirmation du Pod."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La modalità Silenzia Pod sopprime tutti i segnali acustici di avviso e promemoria di conferma del Pod."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サイレンス・ポッドモードは、ポッドの警告音と確認リマインダーのビープ音をすべて抑えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "무음 파드 모드는 모든 파드 경고 및 확인 알림 신호음이 울리지 않도록 합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stillemodus for pod undertrykker all varsling og bekreftelsespip fra pod."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stille Podmodus dempt alle Podalarmen en bevestigingsmeldingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modul Pompă Silențioasă suprimă toate semnalele sonore de alertă și notificările de confirmare ale pompei."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Беззвучный режим Пода отключает все звуковые сигналы и напоминания о подтверждении Пода."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Režim Silence Pod potlačí všetky upozornenia Pod a upozornenia na potvrdenie."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Način Silence Pod utiša vsa opozorila Pod in opomnike za potrditev."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Under tyst poddläge stängs alla poddens ljud av."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode suppresses all Pod alert and confirmation reminder beeping."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Режим Silence Pod пригнічує всі звукові сигнали сповіщень і нагадувань про підтвердження."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chế độ Silence Pod sẽ chặn tất cả tiếng bíp và lời nhắc nhở."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "静音 Pod 模式会关闭所有 Pod 警报和确认提醒的蜂鸣声。"
          }
        }
      }
    },
    "Silence Pod mode will remain in effect until Disabled or the Silence End time has been reached" : {
      "comment" : "Silence End time description",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيظل وضع كبسولة الصمت ساري المفعول حتى يتم تعطيله أو بلوغ وقت انتهاء الصمت"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Režim Silence Pod zůstane v platnosti, dokud nebude zakázán nebo dokud nebude dosaženo času ukončení ticha."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod-tilstanden forbliver i kraft, indtil den er deaktiveret, eller Silence End-tiden er nået."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Silence Pod-Modus bleibt so lange in Kraft, bis er deaktiviert wird oder die Silence-Endzeit erreicht ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod mode will remain in effect until Disabled or the Silence End time has been reached"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El modo Silencio Pod permanecerá activo hasta que se desactive o se alcance la hora de finalización del silencio."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod -tila pysyy voimassa, kunnes Disabled tai Silence End -aika on saavutettu."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mode Silence Pod reste en vigueur jusqu'à ce qu'il soit désactivé ou que l'heure de fin de silence soit atteinte."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מצב שקע שתיקה יישאר בתוקף עד להשבית או להגיע לזמן סיום השתיקה"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Silence Pod üzemmód addig marad érvényben, amíg a kikapcsolás vagy a Silence End idő el nem éri a következő időt"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La modalità Silence Pod rimarrà attiva fino a quando non sarà disattivata o non sarà stato raggiunto il tempo di fine silenzio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サイレンスポッドモードは、無効化されるか、サイレンス終了時間に達するまで有効です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "침묵 포드 모드는 사용 안 함 또는 침묵 종료 시간에 도달할 때까지 유효합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod-modus forblir i kraft til den er Deaktivert eller Silence End-tiden er nådd"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De modus Silence Pod blijft van kracht totdat deze wordt uitgeschakeld of de eindtijd voor stilte is bereikt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryb Silence Pod będzie działał do momentu wyłączenia lub osiągnięcia czasu zakończenia ciszy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O modo de cápsula de silêncio permanecerá em vigor até ser desativado ou o tempo de fim de silêncio ter sido atingido"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modul Silence Pod va rămâne în vigoare până la dezactivare sau până la atingerea timpului Silence End"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Режим Silence Pod будет действовать до тех пор, пока не будет отключен или не будет достигнуто время окончания режима Silence End"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Režim Silence Pod zostane v platnosti, kým sa nevypne alebo kým sa nedosiahne čas ukončenia ticha."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Način Silence Pod ostane v veljavi, dokler ni onemogočen ali dokler ni dosežen čas konca tišine."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Silence Pod-läget fortsätter att gälla tills det inaktiveras eller tills Silence End-tiden har uppnåtts"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessizlik Bölmesi modu Devre Dışı bırakılana veya Sessizlik Sonu süresine ulaşılana kadar etkin kalacaktır"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Режим Silence Pod буде діяти до вимкнення або закінчення часу вимкнення тиші."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chế độ Silence Pod sẽ vẫn có hiệu lực cho đến khi Tắt hoặc đến thời gian Kết thúc Im lặng"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在禁用或达到静音结束时间之前，静音舱模式一直有效。"
          }
        }
      }
    },
