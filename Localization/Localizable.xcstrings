        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All Pod alerts use no beeps and confirmation reminder beeps are suppressed. The Pod will only beep for fatal Pod faults and when playing test beeps.\n\n⚠️Warning - If your phone is out of range of the pod while this feature is enabled, you will not receive any in-app notifications; and the pod will not beep to alert you."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tất cả cảnh báo của Pod không phát tiếng bíp, và tiếng bíp nhắc xác nhận cũng bị tắt. Pod chỉ phát tiếng bíp khi xảy ra lỗi nghiêm trọng hoặc khi thực hiện bài kiểm tra tiếng bíp.\n\n⚠️ Cảnh báo – Nếu điện thoại của bạn ngoài phạm vi kết nối với Pod khi tính năng này được bật, bạn sẽ không nhận được bất kỳ thông báo nào trong ứng dụng, và Pod cũng sẽ không bíp để cảnh báo bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All Pod alerts use no beeps and confirmation reminder beeps are suppressed. The Pod will only beep for fatal Pod faults and when playing test beeps.\n\n⚠️Warning - If your phone is out of range of the pod while this feature is enabled, you will not receive any in-app notifications; and the pod will not beep to alert you."
          }
        }
      }
    },
