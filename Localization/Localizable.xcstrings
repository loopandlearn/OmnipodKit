    "Remove %1$@ needle cap and check cannula. Then remove paper backing." : {
      "comment" : "Label text for step two of attach pod instructions (1: pod tab color",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بإزالة غطاء الإبرة %@ وفحص القنية. ثم قم بإزالة الدعامة الورقية."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sejměte kryt jehly %@ a zkontrolujte kanylu. Poté odstraňte papírovou podložku."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fjern %@ nålehætten, og tjek kanylen. Fjern derefter bagsidepapiret."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nadelkappe %@ entfernen und Kanüle überprüfen. Dann die Papierunterlage entfernen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove %@ needle cap and check cannula. Then remove paper backing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retire el capuchón de la aguja %@ y compruebe la cánula. A continuación, retire el soporte de papel."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poista %@-neulan korkki ja tarkista kanyyli. Poista sitten paperinen taustapaperi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retirer le capuchon de l'aiguille %@ et vérifier la canule. Retirer ensuite le support papier."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הסר את מכסה המחט %@ ובדוק את הצינורית. לאחר מכן הסר את גיבוי הנייר."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Távolítsa el a %@ tűsapkát és ellenőrizze a kanült. Ezután távolítsa el a papír hátlapot."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimuovere il cappuccio dell'ago %@ e controllare la cannula. Quindi rimuovere il supporto di carta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "xxx0xx}針のキャップを外し、カニューレを確認します。次に裏紙を取り外します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "XX0XX} 바늘 캡을 제거하고 캐뉼라를 확인합니다. 그런 다음 종이 뒷면을 제거합니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fjern %@ nålehetten og kontroller kanylen. Fjern deretter papirunderlaget."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwijder %@ naaldkap en controleer de canule. Verwijder dan de papieren achterkant."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdejmij nasadkę igły %@ i sprawdź kaniulę. Następnie usuń papierowy podkład."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retirar a tampa da agulha %@ e verificar a cânula. Em seguida, retirar o suporte de papel."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Îndepărtați capacul acului %@ și verificați canula. Apoi îndepărtați suportul de hârtie."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Снимите колпачок иглы %@ и проверьте канюлю. Затем удалите бумажную подложку."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odstráňte kryt ihly %@ a skontrolujte kanylu. Potom odstráňte papierovú podložku."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odstranite pokrovček igle %@ in preverite kanilo. Nato odstranite papirnato podlago."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ta bort %@ nållock och kontrollera kanylen. Ta sedan bort pappersbaksidan."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "xx0xx} iğne kapağını çıkarın ve kanülü kontrol edin. Ardından kağıt desteğini çıkarın."
          }
