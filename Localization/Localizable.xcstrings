          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre Pod est prêt à être utilisé.\n\nLe rappel par défaut a été programmé pour ce Pod lors de la configuration. Vous pouvez modifier l'heure du rappel dans les paramètres de notification du Pod pour choisir un moment plus pratique."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo Pod è pronto per l'uso. \n \nIl promemoria predefinito è stato programmato per questo Pod al momento della configurazione. Puoi modificare il promemoria impostando un orario più comodo nelle Impostazioni di notifica del Pod."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポッドは使用可能です。\n\nこのPodにはセットアップ時にデフォルトのリマインダーが設定されています。リマインダーは「Pod通知設定」で都合の良い時間に変更できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod를 사용할 준비가 되었습니다.\n\n설정 시 이 파드에 대한 기본 알림이 예약되었다. 파드 알림 설정에서 더 편리한 시간으로 알림을 변경할 수 있다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod er nå klar til bruk.\n\nStandardpåminnelsen ble planlagt for denne pod under oppsettet. Du kan endre påminnelsen til et mer passende tidspunkt i varslingsinnstillingene for pod."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je Pod is klaar voor gebruik.\n\nDe standaard herinnering is op installatie voor deze Pod ingepland. Je kunt de herinnering veranderen naar een handigere tijd in Pod Meldingsinstellingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pompa este gata de utilizare.\n\nNotificarea implicită a fost programată pentru această pompă la configurare. Puteți schimba notificarea la o oră mai convenabilă în Configurări notificări pompă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod je pripravljen za uporabo.\n\nPri nastavitvi je bil za ta pod načrtovan privzeti opomnik. Opomnik lahko spremenite na primernejši čas v nastavitvah za obvestila za pod."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din Pod är nu klar för användning.\n\nStandardpåminnelsen blev inställd för denna podd. Du kan ändra påminnelsen till en annan bekvämare tid i inställningarna för poddaviseringar."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod của bạn đã sẵn sàng để sử dụng.\n\nLời nhắc mặc định đã được đặt cho Pod này khi thiết lập. Bạn có thể thay đổi lời nhắc sang thời gian thuận tiện hơn trong phần Cài đặt thông báo Pod."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod 已就绪。\n该 Pod 的默认提醒时间已设置好，您可以在 pod 通知设置中调整为更方便的时间。"
          }
        }
      }
    },
    "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“" : {
      "comment" : "Alert message body for confirm pod attachment",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Váš Pod může stále dodávat inzulín.\nVyjměte jej z těla a klepněte na \"Pokračovat\"."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din Pod leverer muligvis stadig insulin.\nFjern den fra din krop og tryk derefter på \"Fortsæt\"."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Pod gibt möglicherweise immer noch Insulin ab.\nEntferne ihn vom Körper und tippe dann auf „Weiter“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que su Pod siga suministrando insulina.\nRetírelo de su cuerpo y pulse \"Continuar\"."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre Pod peut encore délivrer de l'insuline.\nRetirez-le de votre corps, puis appuyez sur \"Continuer\"."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo Pod potrebbe ancora erogare insulina.\nRimuovilo dal tuo corpo, e poi tocca \"Continua\"."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポッドはまだインスリンを供給しているかもしれません。\nポッドを体から取り外し、\"続ける \"をタップしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod가 여전히 인슐린을 전달하고 있을 수 있습니다.\n몸에서 제거한 다음 \"계속\"을 탭하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod kan fortsatt levere insulin.\nFjern den fra kroppen din, og trykk deretter på \"Fortsett\"."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je Pod kan nog steeds insuline toedienen.\nVerwijder de Pod van je lichaam en tik vervolgens op \"Ga Verder\"."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twój POD może nadal dostarczać insulinę.\nUsuń go z ciała, a następnie wybierz \"Kontynuuj\"."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este posibil ca pompa dumneavoastră să administreze în continuare insulină.\nScoateți-o de pe corpul dumneavoastră, apoi atingeți \"Continuați\"."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваш под может по-прежнему доставлять инсулин.\n Удалите его с тела, затем нажмите «Продолжить»."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaš Pod morda še vedno dovaja inzulin.\nOdstranite ga iz telesa in tapnite \"Nadaljuj\"."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din podd kan eventuellt fortfarande ge Insulin.\nTa bort den från din kropp och tryck sedan på ”Fortsätt.”"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod'unuz hala İnsülin veriyor olabilir.\nVücudunuzdan çıkarın ve ardından \"Devam\"a dokunun."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod may still be delivering Insulin.\nRemove it from your body, then tap “Continue.“"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod của bạn có thể vẫn đang bơm insulin.\nHãy tháo Pod ra khỏi cơ thể, sau đó nhấn “Tiếp tục“"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的 Pod 可能仍在输注胰岛素。\n请先将其从身体上移除，然后点击“继续”。"
          }
        }
      }
    }
