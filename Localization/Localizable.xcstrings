    "Make sure your phone and pod are close to each other. If communication issues persist, move to a new area." : {
      "comment" : "The action string on pod status page when pod data is stale",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Make sure your phone and pod are close to each other. If communication issues persist, move to a new area."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ujistěte se, že váš telefon a pod jsou blízko sebe. Pokud problémy s komunikací přetrvávají, zkuste přesunutí na jiné místo."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sørg for, at din telefon og Pod er tæt på hinanden. Hvis der fortsat er kommunikationsproblemer, skal du flytte til et nyt område."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stelle sicher, dass sich Dein iPhone und Dein Pod nahe beieinander befinden. Wenn die Kommunikationsprobleme bestehen bleiben, dann gehe an einen anderen Ort."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Make sure your phone and pod are close to each other. If communication issues persist, move to a new area."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asegúrese de que su teléfono y su pod estén cerca uno del otro. Si los problemas de comunicación persisten, muévase a otra área."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Make sure your phone and pod are close to each other. If communication issues persist, move to a new area."
          }
        },
        "fr" : {
          "stringUnit" : {
