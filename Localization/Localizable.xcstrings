        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O pod mantém-se ativo quando a aplicação está em primeiro plano com o telemóvel desbloqueado. Pedido de estado do pod adicional emitido após 2 minutos e 40 segundos."
