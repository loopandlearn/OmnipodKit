          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seleccione el tipo de Pod Omnipod que desea utilizar con %@. Asegúrese de seleccionar el tipo de Pod correcto o %@ no podrá comunicarse con él."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitse tietty Omnipod Pod -tyyppi käytettäväksi %@:n kanssa. Varmista, että valitset oikean Pod-tyypin, tai %@ ei pysty kommunikoimaan sen kanssa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
