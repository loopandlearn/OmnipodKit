    "Wait for existing bolus to finish, or cancel bolus" : {
      "comment" : "Recovery suggestion when operation could not be completed due to existing bolus in progress",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
