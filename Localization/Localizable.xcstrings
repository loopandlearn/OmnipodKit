    "Move to a new area away from any other pods and try again" : {
      "comment" : "Recovery suggestion for PodCommsError.tooManyPodsFound",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتقل إلى منطقة جديدة بعيدًا عن أي كبسولات أخرى وحاول مرة أخرى"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přesuňte se do nové oblasti mimo dosah ostatních modulů a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flyt til et nyt område væk fra andre pods, og prøv igen"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Begeben Sie sich in einen neuen Bereich, der von anderen Pods entfernt ist, und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Move to a new area away from any other pods and try again"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muévete a una nueva zona lejos de otras cápsulas e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siirry uudelle alueelle, joka on kaukana muista kapseleista, ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déplacez-vous dans une nouvelle zone éloignée de tout autre pod et réessayez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "עבור לאזור חדש הרחק מתרמילים אחרים ונסה שוב"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menjen egy új területre, távol a többi podtól, és próbálja meg újra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spostarsi in una nuova area lontano da altri baccelli e riprovare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "他のポッドから離れた新しいエリアに移動し、再試行する。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 포드에서 떨어진 새 영역으로 이동한 후 다시 시도하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flytt til et nytt område, vekk fra andre pods, og prøv igjen"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ga naar een nieuw gebied uit de buurt van andere pods en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przenieś się do nowego obszaru z dala od innych kapsuł i spróbuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deslocar-se para uma nova área, longe de outros pods, e tentar novamente"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mutați-vă într-o zonă nouă, departe de orice alte poduri și încercați din nou"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переместитесь в новую зону, подальше от других капсул, и повторите попытку."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Presuňte sa do novej oblasti mimo ostatných strukov a skúste to znova."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premaknite se na novo območje, stran od drugih strokov, in poskusite znova."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flytta till ett nytt område, långt från andra kapslar, och försök igen"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diğer kapsüllerden uzakta yeni bir alana geçin ve tekrar deneyin"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перемістіться на нову ділянку подалі від інших стручків і спробуйте ще раз"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Di chuyển đến một khu vực mới cách xa bất kỳ pod nào khác và thử lại"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "移动到远离其他豆荚的新区域，然后再试一次"
          }
        }
      }
    },
