    "Normal operation mode where audible Pod beeps are used for all Pod alerts and when confidence reminders are enabled." : {
      "comment" : "Description for SilencePodPreference.disabled",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وضع التشغيل العادي حيث تُستخدم صفارات البود المسموعة لجميع تنبيهات البود وعند تفعيل تذكيرات التأكيد."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normální provozní režim, ve kterém se zvukové signály Pod používají pro všechna upozornění Pod a když jsou povolena připomenutí důvěry."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal driftstilstand, hvor hørbar Pod bip bruges til alle Pod advarsler, og når tillidspåmindelser er aktiveret."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normaler Operationsmodus, in dem hörbare Pod Signale für alle Pod Alarme verwendet werden und wenn Vertrauenserinnerungen aktiviert sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal operation mode where audible Pod beeps are used for all Pod alerts and when confidence reminders are enabled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modo de operación normal, donde se utilizan pitidos audibles para todas las alertas del Pod y cuando los recordatorios de confianza están habilitados."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal operation mode where audible Pod beeps are used for all Pod alerts and when confidence reminders are enabled."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En mode normal, le Pod émet des bips sonores pour chaque alerte et lorsque les Bip de confirmation sont activés."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal operation mode where audible Pod beeps are used for all Pod alerts and when confidence reminders are enabled."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal operation mode where audible Pod beeps are used for all Pod alerts and when confidence reminders are enabled."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modalità di funzionamento normale in cui vengono utilizzati segnali acustici del Pod per tutti gli avvisi del Pod e quando sono attivi i promemoria di sicurezza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのポッドアラートと信頼性リマインダーが有効な場合に、可聴ポッドビープ音が使用される通常操作モード。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일반 작동 모드는 모든 파드 알림에 대해 가청 파드 신호음이 사용되고 신뢰도 알림이 활성화된 경우입니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal driftsmodus der hørbare pod-pip brukes for alle pod-varsler og når tillitspåminnelser er aktivert."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normale modus waarbij hoorbare piepjes worden gebruikt voor alle Podwaarschuwingen en wanneer bevestigingsmeldingen zijn ingeschakeld."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal operation mode where audible Pod beeps are used for all Pod alerts and when confidence reminders are enabled."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal operation mode where audible Pod beeps are used for all Pod alerts and when confidence reminders are enabled."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modul normal de funcționare, în care semnalele acustice ale pompei sunt utilizate pentru toate alertele pompei și atunci când sunt activate notificările de confirmare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обычный режим работы, при котором звуковые сигналы используются для всех оповещений Пода и при включенных доверенных напоминаниях."
          }
        },
        "sk" : {
