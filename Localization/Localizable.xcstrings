          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que su Pod siga suministrando insulina.\nRetírelo de su cuerpo y pulse \"Continuar\"."
          }
        },
        "fi" : {
