    "Check pod, apply to site, then confirm pod attachment." : {
      "comment" : "Label text for step three of attach pod instructions",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحقق من الجراب، ثم قم بتطبيقه على الموقع، ثم قم بتأكيد إرفاق الجراب."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
