            "value" : "Капсулы Omnipod DASH имеют синюю игольчатую вкладку с 12-значным номером LOT, обычно начинающимся с 'PD1'."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pody Omnipod DASH majú modrú záložku ihly s 12-miestnym číslom šarže, ktoré sa zvyčajne začína \"PD1\"."
          }
        },
        "sl" : {
