          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spróbuj wyregulować położenie kapsuły lub wyłącz i włącz Bluetooth w Ustawieniach iPhone'a."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
