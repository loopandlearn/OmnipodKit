    "Try adjusting pod position or toggle Bluetooth off and then on in iPhone Settings" : {
      "comment" : "Recovery suggestion for possible bluetooth issue",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حاول ضبط وضع الجراب أو قم بإيقاف تشغيل البلوتوث ثم تشغيله في إعدادات iPhone"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zkuste upravit polohu podů nebo vypnout a zapnout Bluetooth v nastavení iPhonu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prøv at justere pod-positionen, eller slå Bluetooth fra og til i iPhone-indstillingerne."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versuchen Sie, die Position des Pods anzupassen oder schalten Sie Bluetooth in den iPhone-Einstellungen aus und wieder ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Try adjusting pod position or toggle Bluetooth off and then on in iPhone Settings"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prueba a ajustar la posición de la cápsula o desactiva y activa el Bluetooth en los Ajustes del iPhone."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kokeile säätää jalustan asentoa tai kytke Bluetooth pois päältä ja sitten päälle iPhonen Asetuksissa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Essayez d'ajuster la position du pod ou de désactiver puis d'activer le Bluetooth dans les réglages de l'iPhone."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "נסה להתאים את מיקום התרמיל או לכבות את Bluetooth ולאחר מכן להפעיל אותו בהגדרות iPhone"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Próbálja meg beállítani a pod pozícióját, vagy kapcsolja ki, majd be a Bluetooth funkciót az iPhone beállításaiban."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
