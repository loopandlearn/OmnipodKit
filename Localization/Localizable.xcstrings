    "Your insulin delivery will not be automatically adjusted until the temporary basal rate finishes or is canceled." : {
      "comment" : "Description text on manual temp basal action sheet",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لن يتم تعديل توصيل الأنسولين تلقائيًا حتى ينتهي معدل القاعدة المؤقت أو يتم إلغاؤه."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loop automaticky neupraví výdej inzulínu, dokud nastavení dočasné bazální dávky neskončí nebo nebude zrušeno."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loop justerer ikke automatisk din insulindosering, før den midlertidige basalrate er afsluttet eller annulleret."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Insulinabgabe wird nicht automatisch angepasst, bis die temporäre Basalrate beendet oder abgebrochen wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your insulin delivery will not be automatically adjusted until the temporary basal rate finishes or is canceled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su entrega insulina no se ajustará automáticamente hasta que la basal temporal termine o sea cancelada."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your insulin delivery will not be automatically adjusted until the temporary basal rate finishes or is canceled."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre taux d'insuline basale ne sera pas automatiquement ajustée jusqu'à la fin ou l'annulation du taux de basal temporaire."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your insulin delivery will not be automatically adjusted until the temporary basal rate finishes or is canceled."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your insulin delivery will not be automatically adjusted until the temporary basal rate finishes or is canceled."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'erogazione di insulina non verrà regolata automaticamente finché la velocità basale temporanea non sarà terminata o annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一時的な基礎体温が終了するかキャンセルされるまで、インスリン投与量は自動的に調整されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "임시 기저 요법이 끝나거나 취소될 때까지 인슐린 투여량은 자동으로 조정되지 않습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insulintilførselen din vil ikke bli justert automatisk, før den midlertidige basalen er ferdig eller avbrutt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je insuline levering zal niet automatisch worden aangepast totdat de tijdelijke basaalstand is beëindigd of is geannuleerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your insulin delivery will not be automatically adjusted until the temporary basal rate finishes or is canceled."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your insulin delivery will not be automatically adjusted until the temporary basal rate finishes or is canceled."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loop nu va ajusta automat administrarea de insulină până când rata bazală temporară nu se termină sau nu este anulată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подача инсулина не будет автоматизирована до тех пор, пока временная базальная скорость не закончится или не будет отменена."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loop nebude automaticky upravovať podávanie inzulínu, kým dočasná bazálna dávka nebude ukončená alebo zrušená."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dajanje inzulina se ne bo samodejno prilagodilo, dokler se začasna bazalna hitrost ne konča ali prekliče."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din insulintillförsel kommer inte att justeras automatiskt förrän den tillfälliga manella basaldosen avslutas eller avbryts."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loop, geçici bazal oran bitene veya iptal edilene kadar insülin iletiminizi otomatik olarak ayarlamaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваша подача інсуліну не буде автоматично скоригована, доки тимчасова базальна доза не закінчиться або не буде скасована."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Việc cung cấp insulin của bạn sẽ không được điều chỉnh tự động cho đến khi mức cơ bản tạm thời kết thúc hoặc bị hủy bỏ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当前处于临时基础率状态，系统将在该状态结束或被取消后恢复自动调整胰岛素输注。"
          }
        }
      }
    },
    "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings." : {
      "comment" : "Format string for instructions for setup complete view",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pod je připraven k použití.\n\nPři nastavení bylo pro tento Pod naplánováno výchozí připomenutí. Připomínku můžete změnit na vhodnější čas v Nastavení oznámení Podu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Pod is ready for use.\n\nThe default reminder was scheduled for this Pod at setup. You can change the reminder to a more convenient time in Pod Notification Settings."
          }
        },
        "de" : {
