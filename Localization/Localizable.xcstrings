          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tjek bælgen, påfør den på stedet, og bekræft derefter bælgens fastgørelse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prüfen Sie die Hülse, bringen Sie sie am Standort an und bestätigen Sie dann die Befestigung der Hülse."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check pod, apply to site, then confirm pod attachment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compruebe la vaina, aplíquela al lugar y confirme la fijación de la vaina."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tarkista kapseli, kiinnitä se kohteeseen ja vahvista sitten kapselin kiinnitys."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
