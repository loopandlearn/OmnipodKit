    "For use with iPhone 16 or iPhone 17e when used with InPlay BLE (Atlas) DASH pods; otherwise leave disabled." : {
      "comment" : "Hardware which benefits from Pod Keep Alive",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "للاستخدام مع iPhone 16 أو iPhone 17e عند استخدامه مع أجهزة InPlay BLE (Atlas) DASH pods؛ وإلا اتركه معطلاً."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro použití s iPhonem 16 nebo iPhonem 17e, pokud se používá s kapslemi InPlay BLE (Atlas) DASH; jinak nechte vypnuté."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Til brug med iPhone 16 eller iPhone 17e, når den bruges sammen med InPlay BLE (Atlas) DASH-pods; ellers skal den være deaktiveret."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zur Verwendung mit iPhone 16 oder iPhone 17e bei Verwendung mit InPlay BLE (Atlas) DASH Pods; andernfalls deaktiviert lassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For use with iPhone 16 or iPhone 17e when used with InPlay BLE (Atlas) DASH pods; otherwise leave disabled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para uso con iPhone 16 o iPhone 17e cuando se utiliza con InPlay BLE (Atlas) DASH pods; de lo contrario, dejar desactivado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Käytettäväksi iPhone 16:n tai iPhone 17e:n kanssa, kun sitä käytetään InPlay BLE (Atlas) DASH -kapseleiden kanssa; muutoin jätä pois käytöstä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À utiliser avec l'iPhone 16 ou l'iPhone 17e lorsqu'il est utilisé avec les pods DASH InPlay BLE (Atlas) ; sinon, laisser désactivé."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לשימוש עם אייפון 16 או אייפון 17e כאשר משתמשים בו עם תרמילי DASH של InPlay BLE (Atlas); אחרת השאר מושבתים."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iPhone 16 vagy iPhone 17e készülékkel használható, ha az InPlay BLE (Atlas) DASH podokkal együtt használják; egyébként hagyja kikapcsolva."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Da utilizzare con l'iPhone 16 o l'iPhone 17e se utilizzato con le unità DASH InPlay BLE (Atlas); altrimenti lasciare disattivato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "InPlay BLE（Atlas）DASHポッドで使用する場合、iPhone 16またはiPhone 17eで使用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iPhone 16 또는 iPhone 17e와 함께 사용할 경우 InPlay BLE(Atlas) DASH 포드와 함께 사용하며, 그렇지 않은 경우 비활성화 상태로 둡니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For bruk med iPhone 16 eller iPhone 17e når den brukes sammen med InPlay BLE (Atlas) DASH-pods; ellers skal den være deaktivert."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voor gebruik met iPhone 16 of iPhone 17e bij gebruik met InPlay BLE (Atlas) DASH-pods; anders uitgeschakeld laten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do użytku z iPhone'em 16 lub iPhone'em 17e, gdy jest używany z modułami InPlay BLE (Atlas) DASH; w przeciwnym razie pozostaw wyłączony."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para utilização com o iPhone 16 ou iPhone 17e quando utilizado com pods DASH InPlay BLE (Atlas); caso contrário, deixar desativado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pentru utilizare cu iPhone 16 sau iPhone 17e atunci când este utilizat cu capsulele DASH InPlay BLE (Atlas); în caz contrar, lăsați dezactivat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для использования с iPhone 16 или iPhone 17e при использовании с капсулами InPlay BLE (Atlas) DASH; в противном случае отключите."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Na použitie s iPhonom 16 alebo iPhonom 17e, ak sa používa s modulmi InPlay BLE (Atlas) DASH; inak nechajte vypnuté."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Za uporabo z iPhonom 16 ali iPhonom 17e, če se uporablja s podstavki InPlay BLE (Atlas) DASH; sicer pustite onemogočeno."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "För användning med iPhone 16 eller iPhone 17e när den används med InPlay BLE (Atlas) DASH-pods; annars lämnas den inaktiverad."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "InPlay BLE (Atlas) DASH bölmeleriyle kullanıldığında iPhone 16 veya iPhone 17e ile kullanım içindir; aksi takdirde devre dışı bırakın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для використання з iPhone 16 або iPhone 17e при використанні з InPlay BLE (Atlas) DASH pods; в іншому випадку залиште вимкненим."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Để sử dụng với iPhone 16 hoặc iPhone 17e khi sử dụng với InPlay BLE (Atlas) DASH pods; nếu không thì hãy tắt."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与 InPlay BLE (Atlas) DASH pod 一起使用时，适用于 iPhone 16 或 iPhone 17e；否则禁用。"
          }
        }
      }
    },
    "Forget Saved Certificate" : {
